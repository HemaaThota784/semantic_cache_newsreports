# Similarity threshold for semantic cache hits.
# Range: 0.0 to 1.0
# 0.72 = paraphrases hit, different topics dont (recommended)
# 0.90 = only near-identical queries hit
# 0.75 = broader matches hit (may return wrong results)
CACHE_THRESHOLD=0.72

# Number of results to return per query
TOP_K_RESULTS=5

# Embedding model (change only if you want higher quality at slower speed)
# all-MiniLM-L6-v2  = fast, 384-dim (default)
# all-mpnet-base-v2 = slower, 768-dim, higher quality
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Paths (only change if you move the chroma_db or models folders)
CHROMA_DIR=./chroma_db
CLUSTERER_PATH=./models/soft_clusterer.pkl
